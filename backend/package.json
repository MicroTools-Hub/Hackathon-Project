{
  "name": "wholesaleledger-backend",
  "version": "1.0.0",
  "description": "Node.js backend for WholesaleLedger WhatsApp AI payment tracking.",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "check": "node --check index.js && node scripts/check-modules.js",
    "tunnel": "..\\tools\\cloudflared.exe tunnel run wholesale-ledger-tunnel",
    "tunnel:temp": "..\\tools\\cloudflared.exe tunnel --url http://127.0.0.1:3000",
    "tunnel:ngrok": "..\\tools\\ngrok.exe http 127.0.0.1:3000 --url smirk-blighted-marvelous.ngrok-free.dev"
  },
  "dependencies": {
    "@google/generative-ai": "latest",
    "@whiskeysockets/baileys": "latest",
    "cors": "latest",
    "dotenv": "latest",
    "express": "latest",
    "groq-sdk": "latest",
    "multer": "latest",
    "node-cron": "latest",
    "p-queue": "latest",
    "pino": "latest",
    "qrcode": "latest",
    "qrcode-terminal": "latest",
    "sharp": "latest",
    "uuid": "latest"
  },
  "devDependencies": {}
}
