PORT=3000
HOST=127.0.0.1

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

GROQ_API_KEY=
GROQ_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

SESSION_DIR=./sessions
WHISPER_CPP_PATH=./whisper.cpp/main
WHISPER_CPP_MODEL=./models/ggml-base.bin

# Kept as first-run seed fallback if the Supabase trusted_numbers table is empty
TRUSTED_NUMBERS=+919876500001,+919876500002
OWNER_NUMBER=919876500001

# Supabase — trusted numbers are stored here as source of truth
# Use the SERVICE ROLE key (not anon) — never expose this to the browser
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
BUSINESS_NAME=Ramesh Traders
BUSINESS_PREFIX=RAM
ALLOW_GROUPS=false
START_WHATSAPP=true
DEMO_MODE=false
PROCESSING_CONCURRENCY=1
PROCESSING_INTERVAL_CAP=12
PROCESSING_INTERVAL_MS=60000

FRONTEND_URL=https://hackathon-project-bice-tau.vercel.app
FRONTEND_ORIGIN=https://hackathon-project-bice-tau.vercel.app
